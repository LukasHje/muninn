---
import Sidebar from "src/components/Sidebar.astro";
import Icon from "src/components/Icon.astro";
import { getLanguage, ui } from "src/i18n";
import { buildSidebarExperienceLinks } from "src/lib/experiences/sidebar";
import { getFavoritesCount } from "src/lib/favorites";
import { getScratchpadNotesCount } from "src/lib/scratchpad";
import { getLibraryItems, getSidebarNavigation } from "src/lib/vault";
import { ClientRouter } from "astro:transitions";
import "src/styles/global.css";

interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = ui.meta.defaultDescription,
} = Astro.props;
const mobileTitle = title.replace(/\s+[|–—-]\s+Muninn$/i, "");

const [favoritesCount, scratchpadNotesCount, libraryItems] = await Promise.all([
	getFavoritesCount(),
	getScratchpadNotesCount(),
	getLibraryItems(),
]);
const sidebarExperiences = buildSidebarExperienceLinks(libraryItems);
const navigation = getSidebarNavigation().map((item) => {
	if (item.href === "/scratchpad") {
		return { ...item, count: scratchpadNotesCount };
	}

	if (item.href === "/favorites") {
		return { ...item, count: favoritesCount };
	}

	return item;
});
---

<!doctype html>
<html lang={getLanguage()} transition:animate="none">
		<head>
			<meta charset="utf-8" />
			<link transition:persist="favicon-svg" rel="icon" type="image/svg+xml" href="/favicon.svg" />
			<link
				transition:persist="favicon-png"
				rel="icon"
				type="image/png"
				sizes="96x96"
				href="/favicon-96x96.png"
			/>
			<link transition:persist="favicon-ico" rel="icon" href="/favicon.ico" />
			<link
				transition:persist="apple-touch-icon"
				rel="apple-touch-icon"
				sizes="180x180"
				href="/apple-touch-icon.png"
			/>
			<link transition:persist="web-manifest" rel="manifest" href="/site.webmanifest" />
			<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
			<meta name="generator" content={Astro.generator} />
			<meta name="description" content={description} />
			<meta name="theme-color" content="#faf7f2" />
			<title>{title}</title>
			<ClientRouter fallback="swap" />
		</head>
	<body class="overflow-hidden">
		<div
			class="application-shell"
			data-application-shell
			data-overlay="none"
		>
			<header class="mobile-header xl:hidden" data-mobile-header>
				<button
					type="button"
					class="mobile-shell-button"
					data-sidebar-drawer-open
					aria-label={ui.applicationShell.openNavigation}
					aria-controls="application-sidebar-drawer"
					aria-expanded="false"
				>
					<Icon name="menu" class="h-5 w-5" />
				</button>
				<p class="min-w-0 flex-1 truncate px-2 text-center text-sm font-semibold text-slate-800">
					{mobileTitle}
				</p>
				<span class="h-11 w-11 shrink-0" aria-hidden="true"></span>
			</header>

			<div class="application-shell__workspace">
				<button
					type="button"
					class="application-overlay-backdrop"
					data-sidebar-drawer-backdrop
					aria-label={ui.applicationShell.closeNavigation}
					tabindex="-1"
				></button>

				<div
					id="application-sidebar-drawer"
					class="application-sidebar-drawer"
					data-sidebar-drawer
				>
					<Sidebar navigation={navigation} experiences={sidebarExperiences} />
				</div>

				<main
					class="application-main-workspace min-w-0"
					data-main-workspace
				>
					<slot />
				</main>
			</div>

			<div class="application-shell__overlay-layer" data-shell-overlay-layer></div>
		</div>

		<script>
			import initApplicationShell from "src/components/ApplicationShellClient.ts";

			initApplicationShell();
			document.addEventListener("astro:page-load", initApplicationShell);
		</script>
	</body>
</html>
