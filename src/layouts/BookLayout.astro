---
import { ui, withSiteName } from "i18n";
import MainLayout from "layouts/MainLayout.astro";

interface Props {
	title?: string;
	description?: string;
}

const {
	title = withSiteName(ui.pages.books.title),
	description = ui.pages.books.heroDescription,
} = Astro.props;
---

<MainLayout title={title} description={description}>
	<slot />
</MainLayout>
