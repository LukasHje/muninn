---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<header class="-mx-5 bg-transparent px-5 py-3 md:-mx-6 md:px-6">
	<div class="flex items-center justify-between gap-3">
		<div class="flex min-w-0 items-center gap-3">
			<slot name="leading" />
			<h2 class="truncate text-[1.08rem] font-semibold tracking-[-0.03em] text-slate-900">
				{title}
			</h2>
		</div>
		<div class="flex items-center gap-2">
			<slot name="actions" />
		</div>
	</div>
</header>
