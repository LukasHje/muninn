---
import GenericNoteCard from "src/components/experiences/cards/GenericNoteCard.astro";
import ProductCard from "src/components/experiences/cards/ProductCard.astro";
import type { ExperienceDefinition } from "src/lib/experiences/registry";
import type { LibraryItem } from "src/lib/vault";

interface Props {
	definition: ExperienceDefinition;
	note: LibraryItem;
	selected?: boolean;
	redirectTo?: string;
	index?: number;
}

const {
	definition,
	note,
	selected = false,
	redirectTo = Astro.url.pathname + Astro.url.search,
	index = 0,
} = Astro.props;

const cardFamilyComponents = {
	product: ProductCard,
	"generic-note": GenericNoteCard,
};

const CardComponent = cardFamilyComponents[definition.cardFamily] ?? GenericNoteCard;
---

<CardComponent definition={definition} note={note} selected={selected} redirectTo={redirectTo} index={index} />
