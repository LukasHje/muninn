---
import { getInspectorHighlightIconSrc, type InspectorHighlightKey } from "src/lib/experiences/inspectorHighlights";

interface Props {
	title: string;
	className?: string;
	highlightKey?: InspectorHighlightKey;
	surface?: "plain" | "panel";
}

const { title, className = "", highlightKey, surface = "plain" } = Astro.props;
const highlightIconSrc = highlightKey ? getInspectorHighlightIconSrc(highlightKey) : null;
---

<section
	class:list={[
		"experience-inspector-section",
		surface === "panel" ? "rounded-[10px] border border-[#d9d8c7] bg-[rgba(142,156,113,0.08)] px-5 py-4" : "",
		className,
	]}
>
	<div class="flex items-center gap-3">
		{
			highlightIconSrc && (
				<img
					src={highlightIconSrc}
					alt=""
					class="h-6 w-6 shrink-0 object-contain"
					loading="lazy"
				/>
			)
		}
		<h3 class="text-[1.65rem] font-semibold tracking-tight text-slate-900">{title}</h3>
	</div>
	<div class="mt-2">
		<slot />
	</div>
</section>
