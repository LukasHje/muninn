---
import Icon from "src/components/Icon.astro";
import ExperienceStatistics from "src/components/experiences/ExperienceStatistics.astro";
import type { ExperienceDefinition } from "src/lib/experiences/registry";
import type { ExperienceStatistic } from "src/lib/experiences/statistics";

interface Props {
	definition: ExperienceDefinition;
	statistics: ExperienceStatistic[];
}

const { definition, statistics } = Astro.props;
---

<div class="relative overflow-hidden">
	<div class="absolute inset-y-0 right-0 hidden w-[320px] xl:block" aria-hidden="true">
		<div class="absolute inset-0 bg-[radial-gradient(circle_at_right_center,rgba(255,255,255,0.18),rgba(247,242,235,0.04)_52%,transparent_76%)]"></div>
		<img
			src={definition.heroArtwork}
			alt=""
			class="pointer-events-none absolute inset-0 h-full w-full object-contain px-6 py-4 opacity-[0.08] mix-blend-multiply"
		/>
	</div>

		<div class="relative z-10 grid gap-5 xl:grid-cols-[minmax(0,1fr)_320px] xl:gap-4">
			<div class="space-y-4 p-4 md:p-5 xl:p-5 xl:pr-6">
				<div class="flex items-center gap-3 text-sm font-medium text-slate-400">
					<span>Experiences</span>
					<span aria-hidden="true">/</span>
					<span class="text-slate-600">{definition.title}</span>
			</div>

				<div class="flex items-start gap-3.5 md:gap-4">
					<div class="flex h-[4rem] w-[4rem] shrink-0 items-center justify-center rounded-[22px] border border-[#e7dfd3] bg-[#fbf7f1] shadow-[0_8px_18px_rgba(15,23,42,0.04)]">
						<Icon name={definition.icon} class="h-7 w-7 text-slate-700" />
					</div>

					<div class="min-w-0 space-y-2.5">
						<h1 class="text-[3.25rem] font-semibold tracking-[-0.07em] text-slate-900 md:text-[3.8rem] xl:text-[4.1rem] xl:leading-[0.92]">
							{definition.title}
						</h1>
					<p class="max-w-2xl text-[0.98rem] leading-7 text-slate-600 md:text-[1rem]">
						{definition.description}
					</p>
					<ExperienceStatistics items={statistics} />
				</div>
			</div>
		</div>

		<div class="hidden xl:block" aria-hidden="true"></div>
	</div>
</div>

<div class="px-4 py-3 md:px-5 xl:px-5 xl:py-3">
	<slot />
</div>
