---
import Icon from "src/components/Icon.astro";
import ExperienceStatistics from "src/components/experiences/ExperienceStatistics.astro";
import type { ExperienceDefinition } from "src/lib/experiences/registry";
import type { ExperienceStatistic } from "src/lib/experiences/statistics";

interface Props {
	definition: ExperienceDefinition;
	statistics: ExperienceStatistic[];
}

const { definition, statistics } = Astro.props;
const heroArtwork = definition.assets.heroArtwork;
---

<div class="relative -mx-4 -mt-4 overflow-hidden md:-mx-5 md:-mt-5 xl:-mx-6 xl:-mt-6">
	{
		heroArtwork && (
			<div class="pointer-events-none absolute inset-y-0 right-0 hidden w-[42%] md:block" aria-hidden="true">
				<img
					src={heroArtwork}
					alt=""
					class="h-full w-full object-contain p-5 opacity-[0.12] mix-blend-multiply"
					width="1000"
					height="1000"
					loading="eager"
					fetchpriority="high"
					decoding="async"
				/>
			</div>
		)
	}

	<div class="relative z-10 space-y-3 p-4 md:space-y-5 md:p-7">
		<div class="flex items-start gap-4">
			<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border border-[#e2d9cd] bg-white/70 shadow-[0_8px_20px_rgba(15,23,42,0.04)] md:h-14 md:w-14">
				<Icon name={definition.icons.hero} class="h-6 w-6 text-[#585E66] md:h-7 md:w-7" />
			</div>
			<div class="min-w-0">
				<p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Experience</p>
				<h1 class="mt-1 text-[2rem] font-semibold leading-none tracking-[-0.055em] text-slate-900 md:text-[3.2rem]">
					{definition.title}
				</h1>
				<p class="mt-2 line-clamp-2 max-w-2xl text-sm leading-6 text-slate-600 md:mt-3 md:line-clamp-none md:leading-7">{definition.description}</p>
			</div>
		</div>
		<ExperienceStatistics items={statistics} />
	</div>
</div>

<div class="border-t border-[#e3dbd0] px-4 py-3 md:px-5">
	<slot />
</div>
