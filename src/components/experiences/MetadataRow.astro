---
import ExperienceMetadataIcon from "src/components/experiences/ExperienceMetadataIcon.astro";
import type { ExperienceMetadataIconDescriptor } from "src/lib/experiences/metadataIcons";

interface Props {
	metadataKey: string;
	icon: ExperienceMetadataIconDescriptor;
	label: string;
	value: string;
}

const { metadataKey, icon, label, value } = Astro.props;
---

<div class="flex items-start gap-4 py-3">
	<div class="flex min-w-0 items-start gap-3">
		<ExperienceMetadataIcon metadataKey={metadataKey} value={value} className="h-5 w-5 shrink-0" />
		<div class="min-w-0 text-sm leading-6">
			<span class="text-slate-500">{label.toLocaleLowerCase("en")}:</span>
			<span class="ml-2 font-medium text-slate-800">{value}</span>
		</div>
	</div>
</div>
