---
import { formatUiNumber } from "i18n/format";
import { ui } from "i18n";
import Icon from "components/Icon.astro";
import NoteCard from "components/NoteCard.astro";
import NoteListRow from "components/NoteListRow.astro";
import SectionCard from "components/SectionCard.astro";
import TagMultiSelect from "components/TagMultiSelect.astro";
import { getNoteBrowserState } from "lib/noteBrowserState";
import type { LibraryItem } from "lib/vault";

interface Props {
	title: string;
	items: LibraryItem[];
	emptyMessage: string;
	basePath?: string;
}

const {
	title,
	items,
	emptyMessage,
	basePath = Astro.url.pathname,
} = Astro.props;

const searchParams = Astro.url.searchParams;
const searchState = getNoteBrowserState(searchParams);
const { query, category: selectedCategory, tags: selectedTags, sort: sortBy, layout } = searchState;

const categories = Array.from(
	new Map(
		items.map((item) => [
			item.categoryKey,
			{ value: item.categoryKey, label: item.categoryLabel },
		])
	).values()
);

const tagCounts = items.reduce((counts, item) => {
	for (const tag of item.tags) {
		counts.set(tag, (counts.get(tag) ?? 0) + 1);
	}

	return counts;
}, new Map<string, number>());

const tagOptions = Array.from(tagCounts.entries())
	.map(([value, count]) => ({
		value,
		count,
		countLabel: String(count),
	}))
	.sort((left, right) => {
		if (left.count !== right.count) {
			return right.count - left.count;
		}

		return left.value.localeCompare(right.value, "sv");
	});

const selectedTagSet = new Set(selectedTags);

const filteredItems = items
	.filter((item) => {
		const matchesQuery =
			!query ||
			[item.title, item.excerpt, ...item.tags]
				.join(" ")
				.toLowerCase()
				.includes(query.toLowerCase());
		const matchesCategory = selectedCategory === "all" || item.categoryKey === selectedCategory;
		const matchesTag =
			selectedTags.length === 0 || item.tags.some((tag) => selectedTagSet.has(tag));
		return matchesQuery && matchesCategory && matchesTag;
	})
	.sort((a, b) => {
		if (sortBy === "title") {
			return a.title.localeCompare(b.title, "sv");
		}
		return items.indexOf(a) - items.indexOf(b);
	});

const resultsCountLabel = formatUiNumber(filteredItems.length);

function buildLayoutHref(nextLayout: "list" | "grid") {
	const next = new URLSearchParams(searchParams);
	next.set("layout", nextLayout);
	return `${basePath}?${next.toString()}`;
}
---

<div class="space-y-6">
	<section class="surface-panel p-4 md:p-5">
		<div class="flex items-center gap-3 border-b border-[#eee7de] px-1 pb-4">
			<a
				href="/"
				class="inline-flex h-9 w-9 items-center justify-center rounded-xl text-slate-500 transition hover:bg-[#f6f1ea] hover:text-slate-900"
				aria-label={ui.notesBrowser.backToDashboard}
			>
				<Icon name="chevron-left" class="h-4 w-4" />
			</a>
			<h1 class="text-lg font-semibold tracking-tight text-slate-900">{title}</h1>
		</div>

		<form method="get" class="space-y-4 pt-4">
			<input type="hidden" name="layout" value={layout} />
			<label class="block">
				<span class="sr-only">{ui.notesBrowser.searchNotes}</span>
				<span class="flex items-center gap-3 rounded-[14px] border border-[#e7dfd5] bg-white px-4 py-3 shadow-sm">
					<svg
						class="h-4 w-4 shrink-0 text-slate-400"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="1.8"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<circle cx="11" cy="11" r="7"></circle>
						<path d="m20 20-3.5-3.5"></path>
					</svg>
					<input
						class="min-w-0 flex-1 bg-transparent text-sm outline-none placeholder:text-slate-400"
						type="search"
						name="q"
						value={query}
						placeholder={ui.notesBrowser.searchPlaceholder}
					/>
				</span>
			</label>

			<div class="pt-2 flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
				<div class="flex flex-col gap-3 md:flex-row md:flex-wrap md:items-center">
					<label class="relative">
						<span class="sr-only">{ui.notesBrowser.category}</span>
						<select
							name="category"
							class="h-[46px] appearance-none rounded-[12px] border border-[#e7dfd5] bg-white py-2.5 pl-4 pr-10 text-sm font-medium text-slate-700 shadow-sm outline-none transition focus:border-slate-300"
						>
							<option value="all" selected={selectedCategory === "all"}>{ui.notesBrowser.allCategories}</option>
							{
								categories.map((category) => (
									<option
										value={category.value}
										selected={selectedCategory === category.value}
									>
										{category.label}
									</option>
								))
							}
						</select>
						<Icon name="chevron-down" class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400" />
					</label>

					<TagMultiSelect
						name="tag"
						label={ui.notesBrowser.tag}
						allLabel={ui.notesBrowser.allTags}
						searchLabel={ui.notesBrowser.searchTags}
						searchPlaceholder={ui.notesBrowser.searchTagsPlaceholder}
						emptyLabel={ui.notesBrowser.noMatchingTags}
						selectedTags={selectedTags}
						options={tagOptions}
					/>

					<label class="relative">
						<span class="sr-only">{ui.notesBrowser.sort}</span>
						<select
							name="sort"
							class="h-[46px] appearance-none rounded-[12px] border border-[#e7dfd5] bg-white py-2.5 pl-4 pr-10 text-sm font-medium text-slate-700 shadow-sm outline-none transition focus:border-slate-300"
						>
							<option value="updated" selected={sortBy === "updated"}>{ui.notesBrowser.sortByUpdated}</option>
							<option value="title" selected={sortBy === "title"}>{ui.notesBrowser.sortByTitle}</option>
						</select>
						<Icon name="chevron-down" class="pointer-events-none absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-slate-400" />
					</label>

					<button
						type="submit"
						class="rounded-[12px] bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-slate-800"
					>
						{ui.notesBrowser.filter}
					</button>
				</div>

				<div class="flex items-center gap-2">
					<a
						href={buildLayoutHref("list")}
						class:list={[
							"inline-flex h-10 w-10 items-center justify-center rounded-[12px] border shadow-sm transition",
							layout === "list"
								? "border-[#ddd3c5] bg-[#f4efe7] text-slate-900"
								: "border-[#e7dfd5] bg-white text-slate-500 hover:bg-[#faf6ef]",
						]}
						aria-label={ui.notesBrowser.listView}
					>
						<Icon name="layout-list" class="h-4 w-4" />
					</a>
					<a
						href={buildLayoutHref("grid")}
						class:list={[
							"inline-flex h-10 w-10 items-center justify-center rounded-[12px] border shadow-sm transition",
							layout === "grid"
								? "border-[#ddd3c5] bg-[#f4efe7] text-slate-900"
								: "border-[#e7dfd5] bg-white text-slate-500 hover:bg-[#faf6ef]",
						]}
						aria-label={ui.notesBrowser.gridView}
					>
						<Icon name="layout-grid" class="h-4 w-4" />
					</a>
				</div>
			</div>
		</form>
	</section>

	<SectionCard
		title={ui.notesBrowser.results}
		subtitle={ui.notesBrowser.resultsSubtitle(resultsCountLabel)}
		bodyClass={layout === "grid" ? "" : "divide-y divide-[#efe8df]"}
	>
		{
			filteredItems.length === 0 ? (
				<div class="rounded-[16px] border border-dashed border-[#ddd3c5] bg-[#fbf7f1] px-5 py-8 text-sm text-slate-600">
					{emptyMessage}
				</div>
			) : layout === "grid" ? (
				<div class="grid gap-4 md:grid-cols-2 2xl:grid-cols-3">
					{
						filteredItems.map((item) => (
							<NoteCard item={item} selectedTags={selectedTags} />
						))
					}
				</div>
			) : (
				<div>
					{
						filteredItems.map((item) => (
							<NoteListRow item={item} selectedTags={selectedTags} />
						))
					}
				</div>
			)
		}
	</SectionCard>
</div>
