---
import type { LibraryItem } from "src/lib/vault";
import { getNoteLayout } from "src/lib/noteLayout";
import CoverNoteLayout from "src/components/notes/CoverNoteLayout.astro";
import PlainNoteLayout from "src/components/notes/PlainNoteLayout.astro";
import TravelNoteLayout from "src/components/notes/TravelNoteLayout.astro";

interface Props {
	note: LibraryItem;
}

const { note } = Astro.props;
const layout = getNoteLayout(note);
---

{
	layout === "travel" ? (
		<TravelNoteLayout note={note} />
	) : layout === "cover" ? (
		<CoverNoteLayout note={note} />
	) : (
		<PlainNoteLayout note={note} />
	)
}
