---
interface Props {
	values: string[];
	tone?: "slate" | "amber" | "sky";
}

const { values, tone = "slate" } = Astro.props;

const toneClasses = {
	slate: "border border-slate-200/80 bg-slate-100/90 text-slate-600 shadow-[0_6px_16px_rgba(15,23,42,0.05)]",
	amber: "border border-amber-200/80 bg-amber-50 text-amber-700 shadow-[0_6px_16px_rgba(217,119,6,0.08)]",
	sky: "border border-sky-200/80 bg-sky-50 text-sky-700 shadow-[0_6px_16px_rgba(14,165,233,0.08)]",
}[tone];
---

{
	values.length > 0 && (
		<div class="flex flex-wrap gap-2.5">
			{
				values.map((value) => (
					<span
						class:list={[
							"rounded-full px-3.5 py-1.5 text-[0.76rem] font-medium leading-none tracking-[0.01em]",
							toneClasses,
						]}
					>
						{value}
					</span>
				))
			}
		</div>
	)
}
