---
import path from "node:path";
import { Marked, Renderer } from "marked";
import type { Tokens } from "marked";
import MediaSlider from "../media/MediaSlider.astro";
import LeafletMap from "../maps/LeafletMap.astro";
import DataviewResult from "../dataview/DataviewResult.astro";
import { executeDataviewLite } from "../../lib/dataviewLite";
import type { ParsedMapBlock } from "../../lib/parseMapBlock";
import { parseMapBlock } from "../../lib/parseMapBlock";
import type { ResolvedObsidianAsset } from "../../lib/resolveObsidianAsset";
import { parseObsidianAssetRef, resolveObsidianAsset } from "../../lib/resolveObsidianAsset";
import { getVaultAssetIndex } from "../../lib/vaultAssetIndex";
import type { LibraryItem } from "../../lib/vault";
import { getLibraryItems, getNoteLookupIndex } from "../../lib/vault";

interface Props {
	note: LibraryItem;
	content?: string;
}

type ContentSegment =
	| { type: "markdown"; html: string; key: string }
	| { type: "html"; html: string; key: string }
	| { type: "map"; map: ParsedMapBlock; key: string }
	| { type: "slider"; items: ResolvedObsidianAsset[]; key: string }
	| { type: "dataview"; result: ReturnType<typeof executeDataviewLite>; key: string };

const { note, content = note.content } = Astro.props;
const allNotes = await getLibraryItems();
const noteLookup = await getNoteLookupIndex();
const assetIndex = await getVaultAssetIndex();

function escapeHtml(value: string) {
	return value
		.replaceAll("&", "&amp;")
		.replaceAll("<", "&lt;")
		.replaceAll(">", "&gt;")
		.replaceAll('"', "&quot;")
		.replaceAll("'", "&#39;");
}

function escapeAttribute(value: string) {
	return escapeHtml(value);
}

function escapeMarkdownLabel(value: string) {
	return value.replace(/]/g, "\\]");
}

function decodePseudoValue(value: string) {
	return decodeURIComponent(value.replace(/^\w+-?\w*:/, ""));
}

function basenameWithoutExtension(value: string) {
	return path.basename(value, path.extname(value));
}

function buildLookupKeys(value: string) {
	const cleaned = value.replace(/^\/+/, "").replace(/\.md$/i, "").trim();
	if (!cleaned) {
		return [];
	}

	const relativeLower = cleaned.toLowerCase();
	const segments = cleaned.split("/").map((segment) => segment.trim()).filter(Boolean);
	const slugPath = segments
		.map((segment) =>
			segment
				.toLowerCase()
				.normalize("NFD")
				.replace(/\p{Diacritic}/gu, "")
				.replace(/[^a-z0-9]+/g, "-")
				.replace(/^-|-$/g, "")
		)
		.filter(Boolean)
		.join("/");
	const basename = segments.at(-1) ?? cleaned;
	const slugBase = slugPath.split("/").at(-1) ?? slugPath;

	return Array.from(new Set([relativeLower, slugPath, basename.toLowerCase(), slugBase].filter(Boolean)));
}

function resolveWikiLink(target: string) {
	for (const key of buildLookupKeys(target)) {
		const match = noteLookup.get(key);
		if (match) {
			return match;
		}
	}

	return null;
}

function resolveAsset(reference: string, altOverride?: string) {
	const resolved = resolveObsidianAsset(reference, note.relativePath, assetIndex);
	if (altOverride) {
		return { ...resolved, alt: altOverride };
	}
	return resolved;
}

function renderMissingLink(label: string, target: string) {
	return `<span class="note-link-missing" title="Saknad intern länk: ${escapeAttribute(target)}">${escapeHtml(label)}</span>`;
}

function renderMissingImage(reference: string, altText: string) {
	return `<figure class="missing-asset"><div class="missing-asset__icon">Bild saknas</div><figcaption>${escapeHtml(
		altText || reference
	)}</figcaption><p>${escapeHtml(reference)}</p></figure>`;
}

function renderCodeBlock(language: string, code: string) {
	const normalizedLanguage = language.trim().toLowerCase() || "text";
	const escapedCode = escapeHtml(code.replace(/\n$/, ""));

	return `
		<div class="code-block">
			<div class="code-block__toolbar">
				<span class="code-block__language">${escapeHtml(normalizedLanguage)}</span>
				<button type="button" class="code-copy-button" data-copy-code data-copy-value="${escapeAttribute(code)}">Copy</button>
			</div>
			<pre class="code-block__pre"><code class="language-${escapeAttribute(normalizedLanguage)}">${escapedCode}</code></pre>
		</div>
	`;
}

function parseImageTitle(title?: string | null) {
	if (!title?.startsWith("muninn-width:")) {
		return null;
	}

	const parsed = Number.parseInt(title.replace("muninn-width:", ""), 10);
	return Number.isFinite(parsed) ? parsed : null;
}

function isFramedImage(extension?: string) {
	return extension === ".svg" || extension === ".png";
}

function parseMediaSliderItems(raw: string) {
	const lines = raw
		.split("\n")
		.map((line) => line.trim())
		.filter(Boolean);
	const items: ResolvedObsidianAsset[] = [];

	for (const line of lines) {
		const obsidianMatch = line.match(/!\[\[([^\]]+)\]\]/);
		if (obsidianMatch) {
			items.push(resolveAsset(obsidianMatch[1]));
			continue;
		}

		const markdownMatch = line.match(/!\[([^\]]*)\]\(([^)]+)\)/);
		if (markdownMatch) {
			items.push(resolveAsset(markdownMatch[2], markdownMatch[1] || undefined));
		}
	}

	return items;
}

function toMarkdownAssetImage(reference: string, alt = "", width?: number | null) {
	const cleanedReference = reference.replace(/^<|>$/g, "").trim();
	const escapedAlt = escapeMarkdownLabel(alt);
	const title = width ? ` "muninn-width:${width}"` : "";
	return `![${escapedAlt}](muninn-asset:${encodeURIComponent(cleanedReference)}${title})`;
}

function parseMarkdownImageReference(reference: string) {
	const trimmed = reference.trim();
	if (!trimmed) {
		return null;
	}

	const unwrapped = trimmed.startsWith("<") && trimmed.endsWith(">")
		? trimmed.slice(1, -1).trim()
		: trimmed;
	const titleMatch = unwrapped.match(/^(.*?)(?:\s+"([^"]+)")$/);

	return {
		path: (titleMatch?.[1] ?? unwrapped).trim(),
		title: titleMatch?.[2]?.trim(),
	};
}

function preprocessMarkdown(raw: string) {
	return raw
		.replace(/!\[\[([^\]]+)\]\]/g, (_, reference) => {
			const parsed = parseObsidianAssetRef(reference);
			return toMarkdownAssetImage(reference, parsed.alt || basenameWithoutExtension(parsed.path), parsed.width);
		})
		.replace(/<img[^>]*src="([^"]+)"[^>]*alt="([^"]*)"[^>]*>/gi, (_, reference, alt) => {
			return toMarkdownAssetImage(reference, alt || "");
		})
		.replace(/<img[^>]*src="([^"]+)"[^>]*>/gi, (_, reference) => {
			return toMarkdownAssetImage(reference);
		})
		.replace(/!\[([^\]]*)\]\((?!muninn-asset:|https?:|data:|\/vault-assets\/)([^)\n]+)\)/g, (_, alt, reference) => {
			const parsed = parseMarkdownImageReference(reference);
			if (!parsed?.path) {
				return _;
			}

			const width = parsed.title?.startsWith("muninn-width:")
				? Number.parseInt(parsed.title.replace("muninn-width:", ""), 10)
				: null;
			return toMarkdownAssetImage(parsed.path, alt || "", Number.isFinite(width) ? width : null);
		})
		.replace(/\[\[([^|\]]+)\|?([^\]]+)?\]\]/g, (_, target, label) => {
			const text = label || target;
			return `[${text}](muninn-note:${encodeURIComponent(target)})`;
		});
}

const renderer = new Renderer();

renderer.link = function ({ href, title, tokens }: Tokens.Link) {
	const label = this.parser.parseInline(tokens);
	if (href?.startsWith("muninn-note:")) {
		const target = decodePseudoValue(href);
		const resolved = resolveWikiLink(target);
		if (!resolved) {
			return renderMissingLink(label, target);
		}

		return `<a href="${escapeAttribute(resolved)}">${label}</a>`;
	}

	const safeHref = href ? escapeAttribute(href) : "#";
	const titleAttribute = title ? ` title="${escapeAttribute(title)}"` : "";
	return `<a href="${safeHref}"${titleAttribute}>${label}</a>`;
};

renderer.image = function ({ href, title, text }: Tokens.Image) {
	const resolved = resolveAsset(href ?? "", text || undefined);
	if (!resolved.found || !resolved.url) {
		return renderMissingImage(href ?? "", text);
	}

	const width = resolved.width ?? parseImageTitle(title);
	const style = width ? ` style="width:${width}px;max-width:100%"` : "";
	const framedClass = isFramedImage(resolved.extension) ? " muninn-image-frame" : "";

	return `<figure class="muninn-image-figure${framedClass}"><img src="${escapeAttribute(
		resolved.url
	)}" alt="${escapeAttribute(resolved.alt)}" class="muninn-image"${style}></figure>`;
};

const markdown = new Marked({
	gfm: true,
	breaks: true,
	renderer,
});

function renderMarkdownHtml(raw: string) {
	const prepared = preprocessMarkdown(raw);
	const parsed = markdown.parse(prepared);
	return typeof parsed === "string" ? parsed : "";
}

function buildSegments(raw: string): ContentSegment[] {
	const segments: ContentSegment[] = [];
	const blockPattern = /```([^\n`]*)\n([\s\S]*?)```/g;
	let lastIndex = 0;
	let blockIndex = 0;
	let match: RegExpExecArray | null;

	const pushMarkdown = (value: string) => {
		if (!value.trim()) {
			return;
		}
		segments.push({
			type: "markdown",
			html: renderMarkdownHtml(value),
			key: `markdown-${segments.length}`,
		});
	};

	while ((match = blockPattern.exec(raw)) !== null) {
		pushMarkdown(raw.slice(lastIndex, match.index));

		const language = match[1]?.trim().toLowerCase() || "text";
		const blockBody = match[2] ?? "";

		if (language === "media-slider") {
			const items = parseMediaSliderItems(blockBody);
			if (items.length > 0) {
				segments.push({
					type: "slider",
					items,
					key: `slider-${blockIndex}`,
				});
			} else {
				segments.push({
					type: "html",
					html: renderCodeBlock(language, blockBody),
					key: `code-${blockIndex}`,
				});
			}
		} else if (language === "dataview") {
			segments.push({
				type: "dataview",
				result: executeDataviewLite(blockBody, allNotes, note),
				key: `dataview-${blockIndex}`,
			});
		} else if (language === "map" || language === "leaflet") {
			const parsedMap = parseMapBlock(blockBody);
			if (parsedMap) {
				segments.push({
					type: "map",
					map: parsedMap,
					key: `map-${blockIndex}`,
				});
			} else {
				segments.push({
					type: "html",
					html: renderCodeBlock(language, blockBody),
					key: `code-${blockIndex}`,
				});
			}
		} else {
			segments.push({
				type: "html",
				html: renderCodeBlock(language, blockBody),
				key: `code-${blockIndex}`,
			});
		}

		lastIndex = match.index + match[0].length;
		blockIndex += 1;
	}

	pushMarkdown(raw.slice(lastIndex));

	return segments;
}

const segments = buildSegments(content);
---

<article class="note-content prose-surface">
	{
		segments.map((segment) =>
			segment.type === "markdown" || segment.type === "html" ? (
				<div class="note-content__segment" set:html={segment.html}></div>
			) : segment.type === "map" ? (
				<div class="my-7">
					<LeafletMap map={segment.map} />
				</div>
			) : segment.type === "dataview" ? (
				<div class="my-7">
					<DataviewResult result={segment.result} />
				</div>
			) : (
				<div class="my-7">
					<MediaSlider items={segment.items} />
				</div>
			)
		)
	}
</article>

<script is:inline>
	if (!window.__muninnCodeCopyBound) {
		window.__muninnCodeCopyBound = true;
		document.addEventListener("click", async (event) => {
			const target = event.target;
			if (!(target instanceof HTMLElement)) return;
			const button = target.closest("[data-copy-code]");
			if (!(button instanceof HTMLButtonElement)) return;
			const code = button.getAttribute("data-copy-value") ?? "";
			try {
				await navigator.clipboard.writeText(code);
				const original = button.textContent;
				button.textContent = "Copied";
				window.setTimeout(() => {
					button.textContent = original ?? "Copy";
				}, 1200);
			} catch {
				button.textContent = "Failed";
				window.setTimeout(() => {
					button.textContent = "Copy";
				}, 1200);
			}
		});
	}
</script>

