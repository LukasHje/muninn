		margin-top: 2.65rem;
		margin-bottom: 0.95rem;
	}

	.note-content :global(h1[id]),
	.note-content :global(h2[id]),
	.note-content :global(h3[id]),
	.note-content :global(h4[id]),
	.note-content :global(h5[id]),
	.note-content :global(h6[id]) {
