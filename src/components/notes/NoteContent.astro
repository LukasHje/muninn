---
import { Marked, Renderer } from "marked";
import type { Tokens } from "marked";
import type { MarkdownDocumentSegment, MarkdownParseContext } from "src/lib/markdown/types";
import { parseMarkdownDocument } from "src/lib/markdown/pipeline";
import { ui } from "src/i18n";
import { slugifySegment } from "src/lib/parser";
import {
	decodePseudoValue,
	isFramedObsidianImage,
	parseObsidianImageTitle,
	preprocessObsidianMarkdown,
	resolveObsidianAssetForNote,
	resolveObsidianWikiLink,
} from "src/lib/markdown/obsidian";
import { getVaultAssetIndex } from "src/lib/vaultAssetIndex";
import type { LibraryItem } from "src/lib/vault";
import { getLibraryItems, getNoteLookupIndex } from "src/lib/vault";
import Callout from "src/components/obsidian/Callout.astro";
import DataviewJsResult from "src/components/dataview/DataviewJsResult.astro";
import DataviewResult from "src/components/dataview/DataviewResult.astro";
import MediaSlider from "src/components/media/MediaSlider.astro";
import LeafletMap from "src/components/maps/LeafletMap.astro";
import MermaidDiagram from "src/components/plugins/MermaidDiagram.astro";
import MultiColumnBlock from "src/components/plugins/MultiColumnBlock.astro";

interface Props {
	note: LibraryItem;
	content?: string;
	segments?: MarkdownDocumentSegment[];
	markdownContext?: MarkdownParseContext;
}

const { note, content = note.content, segments: providedSegments, markdownContext: providedContext } = Astro.props;
const markdownContext = providedContext ?? {
	note,
	allNotes: await getLibraryItems(),
	noteLookup: await getNoteLookupIndex(),
	assetIndex: await getVaultAssetIndex(),
};
const segments = providedSegments ?? (await parseMarkdownDocument(content, markdownContext));
const imageLightboxGroup = `note-${note.slugPath || note.id}`;
let standaloneLightboxIndex = 0;
const headingIdCounts = new Map<string, number>();

function escapeHtml(value: string) {
	return value
		.replaceAll("&", "&amp;")
		.replaceAll("<", "&lt;")
		.replaceAll(">", "&gt;")
		.replaceAll('"', "&quot;")
		.replaceAll("'", "&#39;");
}

function escapeAttribute(value: string) {
	return escapeHtml(value);
}

function resolveWikiLink(target: string) {
	const resolved = resolveObsidianWikiLink(target, markdownContext.noteLookup);
	if (!resolved) {
		return null;
	}

	const headingHash = resolved.heading ? `#${slugifySegment(resolved.heading)}` : "";
	const currentNoteHref = note.href;

	if (resolved.href === currentNoteHref) {
		return headingHash || "#";
	}

	return `${resolved.href}${headingHash}`;
}

function stripHtmlTags(value: string) {
	return value.replace(/<[^>]+>/g, " ").replace(/\s+/g, " ").trim();
}

function isRecipeNote(currentNote: LibraryItem) {
	return (
		currentNote.normalized.type === "recept" ||
		currentNote.normalized.type === "recipe" ||
		currentNote.normalized.domain === "recept"
	);
}

const recipeIngredientHeadings = new Set(["ingredients", "ingredienser"]);

function decorateRecipeIngredientsSection(html: string) {
	return html.replace(
		/(?:<hr>\s*)?<h([2-6]) id="([^"]+)">([\s\S]*?)<\/h\1>\s*(<(ul|ol)[\s\S]*?<\/\5>)(?:\s*<hr>)?/giu,
		(match, _depth, headingId, headingHtml, listHtml) => {
			const headingText = stripHtmlTags(headingHtml).toLocaleLowerCase("sv-SE");
			if (!recipeIngredientHeadings.has(headingText)) {
				return match;
			}

			return `
				<section class="recipe-ingredients-note" aria-labelledby="${escapeAttribute(headingId)}">
					<div class="recipe-ingredients-note__tape" aria-hidden="true"></div>
					<div class="recipe-ingredients-note__paper">
						<h2 id="${escapeAttribute(headingId)}" class="recipe-ingredients-note__title">${headingHtml}</h2>
						<div class="recipe-ingredients-note__divider" aria-hidden="true"></div>
						<div class="recipe-ingredients-note__list">${listHtml}</div>
					</div>
				</section>
			`;
		}
	);
}

function toHeadingId(value: string) {
	const baseId = slugifySegment(stripHtmlTags(value)) || "section";
	const currentCount = headingIdCounts.get(baseId) ?? 0;
	headingIdCounts.set(baseId, currentCount + 1);
	return currentCount === 0 ? baseId : `${baseId}-${currentCount + 1}`;
}

function resolveAsset(reference: string, altOverride?: string) {
	return resolveObsidianAssetForNote(reference, markdownContext, altOverride);
}

function renderMissingLink(label: string, target: string) {
	return `<span class="note-link-missing" title="${escapeAttribute(ui.noteContent.missingInternalLink(target))}">${escapeHtml(label)}</span>`;
}

function renderMissingImage(reference: string, altText: string) {
	return `<figure class="missing-asset"><div class="missing-asset__icon">${escapeHtml(ui.noteContent.missingImage)}</div><figcaption>${escapeHtml(
		altText || reference
	)}</figcaption><p>${escapeHtml(reference)}</p></figure>`;
}

function isPdfAsset(extension?: string) {
	return extension === ".pdf";
}

function renderCodeBlock(language: string, code: string) {
	const normalizedLanguage = language.trim().toLowerCase() || "text";
	const escapedCode = escapeHtml(code.replace(/\n$/, ""));

	return `
		<div class="code-block">
			<div class="code-block__toolbar">
				<span class="code-block__language">${escapeHtml(normalizedLanguage)}</span>
				<button type="button" class="code-copy-button" data-copy-code data-copy-value="${escapeAttribute(code)}">${escapeHtml(ui.common.copy)}</button>
			</div>
			<pre class="code-block__pre"><code class="language-${escapeAttribute(normalizedLanguage)}">${escapedCode}</code></pre>
		</div>
	`;
}

const renderer = new Renderer();
const defaultTableRenderer = Renderer.prototype.table;

renderer.link = function ({ href, title, tokens }: Tokens.Link) {
	const label = this.parser.parseInline(tokens);
	if (href?.startsWith("muninn-note:")) {
		const target = decodePseudoValue(href);
		const resolved = resolveWikiLink(target);
		if (!resolved) {
			return renderMissingLink(label, target);
		}

		return `<a href="${escapeAttribute(resolved)}">${label}</a>`;
	}

	const safeHref = href ? escapeAttribute(href) : "#";
	const titleAttribute = title ? ` title="${escapeAttribute(title)}"` : "";
	return `<a href="${safeHref}"${titleAttribute}>${label}</a>`;
};

renderer.table = function (token) {
	return `<div class="muninn-table-wrap">${defaultTableRenderer.call(this, token)}</div>`;
};

renderer.heading = function ({ depth, tokens, text }: Tokens.Heading) {
	const content = this.parser.parseInline(tokens);
	const headingId = toHeadingId(text || content);
	return `<h${depth} id="${escapeAttribute(headingId)}">${content}</h${depth}>`;
};

renderer.image = function ({ href, title, text }: Tokens.Image) {
	const resolved = resolveAsset(href ?? "", text || undefined);
	if (!resolved.found || !resolved.url) {
		return renderMissingImage(href ?? "", text);
	}

		const width = resolved.width ?? parseObsidianImageTitle(title);
		const style = width ? ` style="width:${width}px;max-width:100%"` : "";
		const lightboxGroup = `${imageLightboxGroup}-single-${standaloneLightboxIndex += 1}`;
		const usesPdfBranch = isPdfAsset(resolved.extension);

		if (usesPdfBranch) {
		return `<figure class="muninn-pdf-figure" data-muninn-pdf-document data-muninn-pdf-src="${escapeAttribute(
			resolved.url
		)}" data-muninn-pdf-title="${escapeAttribute(resolved.alt)}">
			<div class="muninn-pdf-frame">
				<div class="muninn-pdf-toolbar">
					<span class="muninn-pdf-badge">${escapeHtml(ui.pdf.badge)}</span>
					<span class="muninn-pdf-title">${escapeHtml(resolved.alt)}</span>
					<div class="muninn-pdf-controls">
						<button type="button" class="muninn-pdf-control" data-muninn-pdf-prev aria-label="${escapeAttribute(ui.pdf.previousPage)}">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="m15 18-6-6 6-6"></path>
							</svg>
						</button>
						<span class="muninn-pdf-page-label" data-muninn-pdf-page-label>${escapeHtml(ui.pdf.pageLabel(1, 1))}</span>
						<button type="button" class="muninn-pdf-control" data-muninn-pdf-next aria-label="${escapeAttribute(ui.pdf.nextPage)}">
							<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="m9 18 6-6-6-6"></path>
							</svg>
						</button>
					</div>
				</div>
				<button type="button" class="muninn-pdf-preview" data-muninn-pdf-open aria-label="${escapeAttribute(ui.pdf.openFullscreen)}">
					<div class="muninn-pdf-placeholder" data-muninn-pdf-placeholder>${escapeHtml(ui.pdf.loading)}</div>
					<canvas class="muninn-pdf-canvas" data-muninn-pdf-canvas></canvas>
				</button>
			</div>
		</figure>`;
	}

	const framedClass = isFramedObsidianImage(resolved.extension) ? " muninn-image-frame" : "";

	return `<figure class="muninn-image-figure muninn-image-figure--interactive${framedClass}" data-muninn-lightbox-image data-muninn-lightbox-group="${escapeAttribute(
		lightboxGroup
	)}" data-muninn-lightbox-src="${escapeAttribute(resolved.url)}" data-muninn-lightbox-alt="${escapeAttribute(
		resolved.alt
	)}" data-muninn-lightbox-kind="image" tabindex="0" role="button" aria-label="${escapeAttribute(ui.noteContent.openImage)}">
			<img src="${escapeAttribute(resolved.url)}" alt="${escapeAttribute(resolved.alt)}" class="muninn-image"${style}>
		</figure>`;
};

const markdown = new Marked({
	gfm: true,
	breaks: true,
	renderer,
});

function renderMarkdownHtml(raw: string) {
	const prepared = preprocessObsidianMarkdown(raw);
	const parsed = markdown.parse(prepared);
	if (typeof parsed !== "string") {
		return "";
	}

	return isRecipeNote(note) ? decorateRecipeIngredientsSection(parsed) : parsed;
}
---

<article class="note-content prose-surface">
	{
		segments.map((segment) =>
			segment.type === "markdown" ? (
				<div class="note-content__segment" set:html={renderMarkdownHtml(segment.text)}></div>
			) : segment.type === "code" ? (
				<div class="note-content__segment" set:html={renderCodeBlock(segment.language, segment.code)}></div>
			) : segment.type === "callout" ? (
				<div class="my-7">
					<Callout
						calloutType={segment.calloutType}
						title={segment.title}
						collapsible={segment.collapsible}
						collapsed={segment.collapsed}
					>
						<Astro.self note={note} segments={segment.children} markdownContext={markdownContext} />
					</Callout>
				</div>
			) : segment.type === "multi-column" ? (
				<div class="my-7">
					<MultiColumnBlock columnCount={segment.columnCount}>
						{
							segment.columns.map((column) => (
								<div slot="column" class="multi-column-grid__column">
									<Astro.self note={note} segments={column} markdownContext={markdownContext} />
								</div>
							))
						}
					</MultiColumnBlock>
				</div>
			) : segment.type === "map" ? (
				<div class="my-7">
					<LeafletMap map={segment.map} />
				</div>
			) : segment.type === "dataview" ? (
				<div class="my-7">
					<DataviewResult result={segment.result} />
				</div>
			) : segment.type === "dataviewjs" ? (
				<div class="my-7">
					<DataviewJsResult note={note} result={segment.result} />
				</div>
			) : segment.type === "mermaid" ? (
				<div class="my-7">
					<MermaidDiagram code={segment.code} />
				</div>
			) : (
				<div class="my-7">
					<MediaSlider items={segment.items} />
				</div>
			)
		)
	}
</article>

	<script type="module">
		import initImageLightbox from "src/components/media/ImageLightboxClient.ts";
		import initPdfViewers from "src/components/media/PdfViewerClient.ts";

		initImageLightbox();
		initPdfViewers();

		document.addEventListener("astro:page-load", () => {
			initImageLightbox();
			initPdfViewers();
		});
	</script>

<script
	is:inline
	define:vars={{
		copyLabel: ui.common.copy,
		copiedLabel: ui.common.copied,
		copyFailedLabel: ui.common.copyFailed,
	}}
>
	if (!window.__muninnCodeCopyBound) {
		window.__muninnCodeCopyBound = true;
		document.addEventListener("click", async (event) => {
			const target = event.target;
			if (!(target instanceof HTMLElement)) return;
			const button = target.closest("[data-copy-code]");
			if (!(button instanceof HTMLButtonElement)) return;
			const code = button.getAttribute("data-copy-value") ?? "";
			try {
				await navigator.clipboard.writeText(code);
				const original = button.textContent;
				button.textContent = copiedLabel;
				window.setTimeout(() => {
					button.textContent = original ?? copyLabel;
				}, 1200);
			} catch {
				button.textContent = copyFailedLabel;
				window.setTimeout(() => {
					button.textContent = copyLabel;
				}, 1200);
			}
		});
	}
</script>

<script is:inline>
	if (!window.__muninnSmoothHashLinksBound) {
		window.__muninnSmoothHashLinksBound = true;
		document.addEventListener("click", (event) => {
			const target = event.target;
			if (!(target instanceof HTMLElement)) return;

			const anchor = target.closest('a[href^="#"]');
			if (!(anchor instanceof HTMLAnchorElement)) return;
			if (!anchor.closest(".note-content")) return;

			const rawHash = anchor.getAttribute("href");
			if (!rawHash || rawHash === "#") return;

			const targetId = decodeURIComponent(rawHash.slice(1));
			if (!targetId) return;

			const targetElement = document.getElementById(targetId);
			if (!targetElement) return;

			event.preventDefault();
			targetElement.scrollIntoView({ behavior: "smooth", block: "start" });

			if (window.location.hash !== rawHash) {
				window.history.pushState(null, "", rawHash);
			}
		});
	}
</script>

<style>
	.note-content {
		color: #334155;
		font-size: 1rem;
		line-height: 1.9;
	}

	.note-content :global(.note-content__segment + .note-content__segment) {
