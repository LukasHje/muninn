---
import type { LibraryItem } from "src/lib/vault";
import NoteContent from "src/components/notes/NoteContent.astro";
import NoteShell from "src/components/notes/NoteShell.astro";

interface Props {
	note: LibraryItem;
}

const { note } = Astro.props;
---

<NoteShell note={note} heroStyle="none" metadataImage>
	<section class="mx-auto max-w-[880px]">
		<div class="surface-panel overflow-hidden px-5 py-7 md:px-10 md:py-10">
			<NoteContent note={note} />
		</div>
	</section>
</NoteShell>
