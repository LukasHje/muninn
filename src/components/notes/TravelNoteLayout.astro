---
import type { LibraryItem } from "../../lib/vault";
import LeafletMap from "../maps/LeafletMap.astro";
import { extractMapBlock } from "../../lib/parseMapBlock";
import NoteContent from "./NoteContent.astro";
import NoteShell from "./NoteShell.astro";
import NoteProperties from "./NoteProperties.astro";

interface Props {
	note: LibraryItem;
}

const { note } = Astro.props;
const { map: parsedMap, contentWithoutMap } = extractMapBlock(note.content);
const hasCoordinates =
	Boolean(parsedMap) ||
	Boolean(note.normalized.metadata.lat) ||
	Boolean(note.normalized.metadata.lng) ||
	Boolean(note.normalized.metadata.long) ||
	Boolean(note.normalized.metadata.lon) ||
	Boolean(note.normalized.metadata.coordinates);
---

<NoteShell note={note} heroStyle="travel">
	<section class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_336px] xl:items-start">
		<div class="surface-panel relative overflow-hidden px-5 py-7 md:px-10 md:py-10">
			<div class="absolute inset-x-0 top-0 h-20 bg-[linear-gradient(180deg,rgba(250,247,242,0.72)_0%,rgba(255,255,255,0)_100%)]"></div>
			<div class="relative">
				<NoteContent note={note} content={contentWithoutMap} />
			</div>
		</div>
		<div class="space-y-5 md:space-y-6 xl:sticky xl:top-6">
			<NoteProperties note={note} />
			{
				parsedMap ? (
					<section class="space-y-3">
						<div class="flex items-center justify-between gap-3 px-1">
							<h2 class="panel-title">Karta</h2>
							<span class="rounded-full border border-[#e8ddd0] bg-[#fbf8f2] px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-slate-400">
								Leaflet
							</span>
						</div>
						<LeafletMap map={parsedMap} />
					</section>
				) : hasCoordinates ? (
					<section class="surface-card overflow-hidden p-5 md:p-6">
						<div class="flex items-center justify-between gap-3">
							<h2 class="panel-title">Karta</h2>
							<span class="rounded-full border border-[#e8ddd0] bg-[#fbf8f2] px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-slate-400">
								Kommer snart
							</span>
						</div>
						<div class="mt-4 overflow-hidden rounded-[18px] border border-dashed border-[#d8ccbb] bg-[linear-gradient(180deg,#f8f3ea_0%,#f5efe5_100%)]">
							<div class="grid min-h-[240px] place-items-center bg-[linear-gradient(rgba(148,163,184,0.08)_1px,transparent_1px),linear-gradient(90deg,rgba(148,163,184,0.08)_1px,transparent_1px)] bg-[size:28px_28px] p-6 text-center">
								<div class="space-y-2">
									<p class="text-sm font-semibold text-slate-700">Platsöversikt</p>
									<p class="max-w-[18rem] text-sm leading-6 text-slate-500">
										Har noten koordinater kan en framtida kartvy renderas här utan att ändra layouten.
									</p>
								</div>
							</div>
						</div>
					</section>
				) : (
					<section class="surface-card overflow-hidden p-5 md:p-6">
						<div class="flex items-center justify-between gap-3">
							<h2 class="panel-title">Karta</h2>
							<span class="rounded-full border border-[#e8ddd0] bg-[#fbf8f2] px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-slate-400">
								Kommer snart
							</span>
						</div>
						<div class="mt-4 overflow-hidden rounded-[18px] border border-dashed border-[#d8ccbb] bg-[linear-gradient(180deg,#f8f3ea_0%,#f5efe5_100%)]">
							<div class="grid min-h-[220px] place-items-center bg-[linear-gradient(rgba(148,163,184,0.08)_1px,transparent_1px),linear-gradient(90deg,rgba(148,163,184,0.08)_1px,transparent_1px)] bg-[size:28px_28px] p-6 text-center">
								<div class="space-y-2">
									<p class="text-sm font-semibold text-slate-700">Platsöversikt</p>
									<p class="max-w-[18rem] text-sm leading-6 text-slate-500">
										När en anteckning innehåller ett kartblock renderas Leaflet-kartan här.
									</p>
								</div>
							</div>
						</div>
					</section>
				)
			}
		</div>
	</section>
</NoteShell>
