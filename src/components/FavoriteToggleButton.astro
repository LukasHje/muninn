---
import { ui } from "src/i18n";
import Icon from "src/components/Icon.astro";

interface Props {
	noteId: string;
	isFavorite: boolean;
	redirectTo?: string;
	tone?: "light" | "dark";
	size?: "sm" | "md";
	variant?: "surface" | "chromeless" | "floating";
}

const {
	noteId,
	isFavorite,
	redirectTo = "/notes",
	tone = "light",
	size = "sm",
	variant = "surface",
} = Astro.props;

const sizeClasses =
	size === "md"
		? variant === "chromeless"
			? "h-12 w-12"
			: variant === "floating"
				? "h-10 w-10 rounded-[14px]"
			: "h-11 w-11 rounded-full"
		: variant === "chromeless"
			? "h-7 w-7"
			: variant === "floating"
				? "h-9 w-9 rounded-[12px]"
			: "h-9 w-9 rounded-xl";

const buttonClasses =
	variant === "chromeless"
		? isFavorite
			? "border-transparent bg-transparent text-amber-500 hover:text-amber-600"
			: "border-transparent bg-transparent text-[#c8d0dd] hover:text-slate-600"
		: variant === "floating"
			? isFavorite
				? "border-[#ebd9b0] bg-[rgba(255,251,243,0.96)] text-amber-500 hover:border-[#e3cf9d] hover:text-amber-600"
				: "border-[#e8dfd2] bg-[rgba(255,255,255,0.94)] text-slate-300 hover:border-[#d7cbba] hover:text-amber-500"
		: tone === "dark"
			? isFavorite
				? "border-white/18 bg-white/14 text-amber-300 hover:bg-white/18"
				: "border-white/14 bg-slate-950/18 text-white/72 hover:bg-slate-950/28 hover:text-white"
			: isFavorite
				? "border-amber-200 bg-amber-50 text-amber-500 hover:bg-amber-100"
				: "border-[#e6ddd0] bg-white text-slate-300 hover:border-[#d8cdbd] hover:text-amber-500";
---

<form action="/favorites/toggle" method="post" class="shrink-0">
	<input type="hidden" name="noteId" value={noteId} />
	<input type="hidden" name="redirectTo" value={redirectTo} />
	<button
		type="submit"
		class:list={[
			"inline-flex items-center justify-center transition",
			variant === "surface"
				? "border shadow-sm"
				: variant === "floating"
					? "border shadow-[0_12px_26px_rgba(15,23,42,0.10)]"
					: "border-none shadow-none",
			sizeClasses,
			buttonClasses,
		]}
		aria-label={isFavorite ? ui.favorites.remove : ui.favorites.add}
		title={isFavorite ? ui.favorites.remove : ui.favorites.add}
	>
		<Icon
			name="star"
			filled={isFavorite}
			class:list={[
				variant === "chromeless" && size === "md"
					? "h-6 w-6"
					: variant === "floating"
						? "h-4.5 w-4.5"
						: "h-4 w-4",
			]}
		/>
	</button>
</form>
