---
import { ui } from "src/i18n";
import Icon from "src/components/Icon.astro";

interface Props {
	noteId: string;
	isFavorite: boolean;
	redirectTo?: string;
	tone?: "light" | "dark";
	size?: "sm" | "md";
	variant?: "surface" | "chromeless" | "floating";
}

const {
	noteId,
	isFavorite,
	redirectTo = "/notes",
	tone = "light",
	size = "sm",
	variant = "surface",
} = Astro.props;

const sizeClasses =
	size === "md"
		? variant === "chromeless"
			? "h-12 w-12"
			: variant === "floating"
				? "h-10 w-10 rounded-[14px]"
			: "h-11 w-11 rounded-full"
		: variant === "chromeless"
			? "h-7 w-7"
			: variant === "floating"
				? "h-9 w-9 rounded-[12px]"
			: "h-9 w-9 rounded-xl";

---

<form
	action="/favorites/toggle"
	method="post"
	class="favorite-toggle-form shrink-0"
	data-favorite-toggle
	data-favorite-note-id={noteId}
	data-favorite-state={isFavorite ? "true" : "false"}
	data-favorite-tone={tone}
	data-favorite-variant={variant}
	data-favorite-add-label={ui.favorites.add}
	data-favorite-remove-label={ui.favorites.remove}
>
	<input type="hidden" name="noteId" value={noteId} />
	<input type="hidden" name="redirectTo" value={redirectTo} />
	<button
		type="submit"
		class:list={[
			"favorite-toggle-button inline-flex items-center justify-center transition",
			variant === "surface"
				? "border shadow-sm"
				: variant === "floating"
					? "border shadow-[0_12px_26px_rgba(15,23,42,0.10)]"
					: "border-none shadow-none",
			sizeClasses,
		]}
		aria-label={isFavorite ? ui.favorites.remove : ui.favorites.add}
		aria-pressed={isFavorite ? "true" : "false"}
		title={isFavorite ? ui.favorites.remove : ui.favorites.add}
	>
		<Icon
			name="star"
			filled={isFavorite}
			class:list={[
				variant === "chromeless" && size === "md"
					? "h-6 w-6"
					: variant === "floating"
						? "h-4.5 w-4.5"
						: "h-4 w-4",
			]}
		/>
	</button>
</form>

<style>
	.favorite-toggle-form[data-favorite-variant="chromeless"] .favorite-toggle-button {
		background: transparent;
		color: #c8d0dd;
	}

	.favorite-toggle-form[data-favorite-variant="chromeless"] .favorite-toggle-button:hover {
		color: #475569;
	}

	.favorite-toggle-form[data-favorite-variant="chromeless"][data-favorite-state="true"] .favorite-toggle-button {
		color: #f59e0b;
	}

	.favorite-toggle-form[data-favorite-variant="chromeless"][data-favorite-state="true"] .favorite-toggle-button:hover {
		color: #d97706;
	}

	.favorite-toggle-form[data-favorite-variant="floating"] .favorite-toggle-button {
		border-color: #e8dfd2;
		background: rgba(255, 255, 255, 0.94);
		color: #cbd5e1;
	}

	.favorite-toggle-form[data-favorite-variant="floating"] .favorite-toggle-button:hover {
		border-color: #d7cbba;
		color: #f59e0b;
	}

	.favorite-toggle-form[data-favorite-variant="floating"][data-favorite-state="true"] .favorite-toggle-button {
		border-color: #ebd9b0;
		background: rgba(255, 251, 243, 0.96);
		color: #f59e0b;
	}

	.favorite-toggle-form[data-favorite-variant="floating"][data-favorite-state="true"] .favorite-toggle-button:hover {
		border-color: #e3cf9d;
		color: #d97706;
	}

	.favorite-toggle-form[data-favorite-variant="surface"][data-favorite-tone="light"] .favorite-toggle-button {
		border-color: #e6ddd0;
		background: white;
		color: #cbd5e1;
	}

	.favorite-toggle-form[data-favorite-variant="surface"][data-favorite-tone="light"] .favorite-toggle-button:hover {
		border-color: #d8cdbd;
		color: #f59e0b;
	}

	.favorite-toggle-form[data-favorite-variant="surface"][data-favorite-tone="light"][data-favorite-state="true"] .favorite-toggle-button {
		border-color: #fde68a;
		background: #fffbeb;
		color: #f59e0b;
	}

	.favorite-toggle-form[data-favorite-variant="surface"][data-favorite-tone="light"][data-favorite-state="true"] .favorite-toggle-button:hover {
		background: #fef3c7;
	}

	.favorite-toggle-form[data-favorite-variant="surface"][data-favorite-tone="dark"] .favorite-toggle-button {
		border-color: rgba(255, 255, 255, 0.14);
		background: rgba(2, 6, 23, 0.18);
		color: rgba(255, 255, 255, 0.72);
	}

	.favorite-toggle-form[data-favorite-variant="surface"][data-favorite-tone="dark"] .favorite-toggle-button:hover {
		background: rgba(2, 6, 23, 0.28);
		color: white;
	}

	.favorite-toggle-form[data-favorite-variant="surface"][data-favorite-tone="dark"][data-favorite-state="true"] .favorite-toggle-button {
		border-color: rgba(255, 255, 255, 0.18);
		background: rgba(255, 255, 255, 0.14);
		color: #fcd34d;
	}

	.favorite-toggle-form[data-favorite-variant="surface"][data-favorite-tone="dark"][data-favorite-state="true"] .favorite-toggle-button:hover {
		background: rgba(255, 255, 255, 0.18);
	}

	.favorite-toggle-form[data-favorite-pending="true"] .favorite-toggle-button {
		cursor: progress;
	}
</style>
