---
interface Props {
	title: string;
	subtitle?: string;
	bodyClass?: string;
}

const { title, subtitle, bodyClass = "" } = Astro.props;
---

<section class="surface-panel p-5 md:p-6">
	<div class="mb-4 flex items-start justify-between gap-4">
		<div>
			<h2 class="panel-title">{title}</h2>
			{
				subtitle && <p class="mt-1 text-sm text-slate-500">{subtitle}</p>
			}
		</div>
		<div class="flex items-center gap-2 text-slate-500">
			<slot name="actions" />
		</div>
	</div>
	<div class={bodyClass}>
		<slot />
	</div>
</section>
