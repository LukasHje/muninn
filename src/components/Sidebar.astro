---
import { ui } from "src/i18n";
import Icon from "src/components/Icon.astro";
import QuickSearch from "src/components/QuickSearch.astro";

interface SidebarNavigationItem {
	label: string;
	href: string;
	icon: string;
	count?: number;
}

interface SidebarExperience {
	label: string;
	href: string;
	count: number;
	icon: string;
}

interface Props {
	navigation: SidebarNavigationItem[];
	experiences: SidebarExperience[];
}

const { navigation, experiences } = Astro.props;
const currentPath = Astro.url.pathname;
---

<aside class="sidebar-shell h-fit p-5 md:p-6 xl:flex xl:h-dvh xl:min-h-0 xl:flex-col xl:overflow-hidden">
	<div class="flex shrink-0 items-center gap-3">
		<img
			src="/branding/muninn-neg.svg"
			alt="Muninn"
			class="h-8 w-8 shrink-0"
		/>
		<div>
			<p class="text-[2rem] font-semibold tracking-[-0.04em] text-white">Muninn</p>
		</div>
	</div>

	<div class="mt-6 shrink-0">
		<QuickSearch />
	</div>

	<nav class="mt-5 shrink-0 space-y-1" aria-label={ui.navigation.primaryLabel}>
		{
			navigation.map((item) => (
				(() => {
					const itemPath = new URL(item.href, "http://muninn.local").pathname;
					const isActive =
						itemPath === "/"
							? currentPath === "/"
							: currentPath === itemPath || currentPath.startsWith(`${itemPath}/`);

					return (
				<a
					class:list={[
						"flex items-center gap-3 rounded-2xl px-3 py-3 text-sm font-medium text-white/75 transition hover:bg-white/8 hover:text-white",
						isActive && "bg-white/10 text-white shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]",
					]}
					href={item.href}
				>
					<Icon name={item.icon} class="h-[15px] w-[15px] shrink-0" />
					<span class="min-w-0 flex-1">{item.label}</span>
					{
						typeof item.count === "number" && (
							<span
								class="rounded-full bg-white/8 px-2 py-0.5 text-xs text-white/55"
								data-sidebar-favorites-count={item.href === "/favorites" ? "true" : undefined}
							>
								{item.count}
							</span>
						)
					}
				</a>
					);
				})()
			))
		}
	</nav>

	<div class="mt-8 border-t border-white/10 pt-6 xl:flex xl:min-h-0 xl:flex-1 xl:flex-col">
		<p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-white/30">
			{ui.navigation.experiences}
		</p>
		<ul class="sidebar-experience-list mt-4 space-y-1 xl:min-h-0 xl:max-h-[13.75rem] xl:flex-1 xl:overflow-y-auto xl:overscroll-contain xl:pr-1">
			{
				experiences.map((experience) => (
					<li>
						<a
							class:list={[
								"flex items-center justify-between rounded-2xl px-3 py-2.5 text-sm transition hover:bg-white/6 hover:text-white",
								currentPath === experience.href
									? "bg-white/10 text-white"
									: "text-white/75",
							]}
							href={experience.href}
						>
							<span class="flex items-center gap-3">
								<Icon name={experience.icon} class="h-[15px] w-[15px]" />
								{experience.label}
							</span>
							<span class="text-xs text-white/35">{experience.count}</span>
						</a>
					</li>
				))
			}
		</ul>
	</div>

	<div class="mt-10 shrink-0 xl:mt-6">
		<div class="flex items-center justify-between gap-3 border-t border-white/10 pt-5 text-sm text-white/45">
			<div class="flex items-center gap-2">
				<Icon name="sparkles" class="h-4 w-4" />
				<span>{ui.navigation.poweredByAstro}</span>
			</div>
			<div class="flex shrink-0 items-center gap-2">
				<button
					type="button"
					title={ui.admin.reloadVault}
					aria-label={ui.admin.reloadVault}
					data-vault-reload
					data-vault-reload-endpoint="/api/admin/reload-vault"
					data-vault-reload-idle-label={ui.admin.reloadVault}
					data-vault-reload-running-label={ui.admin.reloadingVault}
					data-vault-reload-success-label={ui.admin.vaultCacheInvalidated}
					data-vault-reload-error-label={ui.admin.reloadVaultFailed}
					data-cooldown="false"
					class="group inline-flex h-9 min-w-9 items-center justify-center gap-2 rounded-xl border border-transparent px-2 text-white transition hover:border-white/10 hover:bg-white/8 disabled:cursor-not-allowed data-[cooldown=true]:rounded-[5px] data-[cooldown=true]:border-sky-300/55 data-[cooldown=true]:bg-transparent data-[cooldown=true]:text-sky-200 data-[cooldown=true]:shadow-[0_0_0_1px_rgba(125,211,252,0.07),0_0_3px_rgba(125,211,252,0.10)] data-[cooldown=true]:hover:bg-transparent"
				>
					<span
						hidden
						data-vault-reload-countdown
						class="text-[11px] font-semibold tabular-nums"
					>30s</span>
					<Icon
						name="database-backup"
						class="h-4 w-4 shrink-0 text-white opacity-[0.55] transition-opacity group-hover:opacity-100 group-data-[cooldown=true]:text-sky-200 group-data-[cooldown=true]:opacity-100"
					/>
				</button>
				<span
					class="inline-flex h-9 w-9 items-center justify-center rounded-xl text-white/55"
					title={ui.admin.darkMode}
					aria-label={ui.admin.darkMode}
				>
					<Icon name="moon" class="h-4 w-4" />
				</span>
			</div>
		</div>
		<p
			hidden
			data-vault-reload-status
			data-state="idle"
			aria-live="polite"
			class="mt-2 text-[11px] leading-4 text-white/50 data-[state=error]:text-rose-200 data-[state=success]:text-emerald-200"
		></p>
	</div>
</aside>

<script type="module">
	import initSidebarControls from "src/components/SidebarClient.ts";

	initSidebarControls();
	document.addEventListener("astro:page-load", initSidebarControls);
</script>
