---
import { ui } from "src/i18n";
import type { SidebarCategory, SidebarNavigationItem } from "src/lib/vault";
import Icon from "src/components/Icon.astro";
import QuickSearch from "src/components/QuickSearch.astro";

interface Props {
	navigation: SidebarNavigationItem[];
	categories: SidebarCategory[];
}

const { navigation, categories } = Astro.props;
const currentPath = Astro.url.pathname;
---

<aside class="sidebar-shell h-fit p-5 md:p-6 xl:sticky xl:top-0">
	<div class="flex items-center gap-3">
		<img
			src="/branding/muninn-neg.svg"
			alt="Muninn"
			class="h-8 w-8 shrink-0"
		/>
		<div>
			<p class="text-[2rem] font-semibold tracking-[-0.04em] text-white">Muninn</p>
		</div>
	</div>

	<div class="mt-6">
		<QuickSearch />
	</div>

	<nav class="mt-5 space-y-1" aria-label={ui.navigation.primaryLabel}>
		{
			navigation.map((item) => (
				(() => {
					const itemPath = new URL(item.href, "http://muninn.local").pathname;
					const isActive =
						itemPath === "/"
							? currentPath === "/"
							: currentPath === itemPath || currentPath.startsWith(`${itemPath}/`);

					return (
				<a
					class:list={[
						"flex items-center gap-3 rounded-2xl px-3 py-3 text-sm font-medium text-white/75 transition hover:bg-white/8 hover:text-white",
						isActive && "bg-white/10 text-white shadow-[inset_0_1px_0_rgba(255,255,255,0.04)]",
					]}
					href={item.href}
				>
					<Icon name={item.icon} class="h-[15px] w-[15px] shrink-0" />
					<span class="min-w-0 flex-1">{item.label}</span>
					{
						typeof item.count === "number" && (
							<span class="rounded-full bg-white/8 px-2 py-0.5 text-xs text-white/55">
								{item.count}
							</span>
						)
					}
				</a>
					);
				})()
			))
		}
	</nav>

	<div class="mt-8 border-t border-white/10 pt-6">
		<p class="text-[11px] font-semibold uppercase tracking-[0.22em] text-white/30">
			{ui.navigation.categories}
		</p>
		<ul class="mt-4 space-y-1">
			{
				categories.map((category) => (
					<li>
						<a
							class="flex items-center justify-between rounded-2xl px-3 py-2.5 text-sm text-white/75 transition hover:bg-white/6 hover:text-white"
							href={category.href}
						>
							<span class="flex items-center gap-3">
								<Icon name={category.icon} class="h-[15px] w-[15px]" />
								{category.label}
							</span>
							<span class="text-xs text-white/35">{category.count}</span>
						</a>
					</li>
				))
			}
		</ul>
	</div>

	<div class="mt-10 flex items-center justify-between border-t border-white/10 pt-5 text-sm text-white/45">
		<div class="flex items-center gap-2">
			<Icon name="sparkles" class="h-4 w-4" />
			<span>{ui.navigation.poweredByAstro}</span>
		</div>
		<Icon name="moon" class="h-4 w-4" />
	</div>
</aside>
