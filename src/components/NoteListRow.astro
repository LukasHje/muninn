---
import type { LibraryItem } from "lib/vault";
import FavoriteToggleButton from "components/FavoriteToggleButton.astro";

interface Props {
	item: LibraryItem;
	selectedTags?: string[];
}

const { item, selectedTags = [] } = Astro.props;
const redirectTo = Astro.url.pathname + Astro.url.search;
const noteHref = `${item.href}?returnTo=${encodeURIComponent(redirectTo)}`;
const selectedTagSet = new Set(selectedTags);
---

<article class="group">
	<div class="flex items-start gap-4 rounded-[14px] px-3 py-3 transition hover:bg-[#fcfaf6]">
		<a href={noteHref} class="flex min-w-0 flex-1 items-start gap-4">
			{
				item.imageUrl ? (
					<img
						src={item.imageUrl}
						alt=""
						class="h-12 w-12 shrink-0 rounded-[10px] object-cover"
						loading="lazy"
					/>
				) : (
					<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-[10px] bg-[#f4efe7] text-xs font-semibold text-slate-500">
						{item.categoryLabel.slice(0, 2)}
					</div>
				)
			}
			<div class="min-w-0 flex-1">
				<div class="flex items-start justify-between gap-4">
					<div class="min-w-0">
						<h2 class="truncate text-[1.05rem] font-semibold tracking-tight text-slate-900">
							{item.title}
						</h2>
						<div class="mt-2 flex flex-wrap gap-2">
							{
								item.tags.map((tag) => (
									<span
										class:list={[
											"rounded-full px-2.5 py-0.5 text-xs font-medium",
											selectedTagSet.has(tag)
												? "bg-sky-100 text-sky-700 ring-1 ring-sky-200"
												: "bg-[#f4efe7] text-slate-500",
										]}
									>
										#{tag}
									</span>
								))
							}
						</div>
					</div>
					<div class="flex shrink-0 items-center gap-4">
						<span class="text-sm text-slate-500">{item.updatedLabel}</span>
					</div>
				</div>
			</div>
		</a>
		<FavoriteToggleButton noteId={item.id} isFavorite={Boolean(item.favorite)} redirectTo={redirectTo} />
	</div>
</article>
