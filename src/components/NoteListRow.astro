---
import { highlightSearchText } from "src/lib/searchHighlight";
import type { NoteSearchMatchField } from "src/lib/noteSearch";
import type { LibraryItem } from "src/lib/vault";
import FavoriteToggleButton from "src/components/FavoriteToggleButton.astro";
import LibraryTagPreview from "src/components/LibraryTagPreview.astro";

interface Props {
	item: LibraryItem;
	selectedTags?: string[];
	searchQuery?: string;
	searchSnippet?: string;
	searchField?: NoteSearchMatchField;
	hrefOverride?: string;
}

const { item, selectedTags = [], searchQuery, searchSnippet, searchField, hrefOverride } = Astro.props;
const redirectTo = Astro.url.pathname + Astro.url.search;

function buildNoteHref(href: string) {
	const [pathAndQuery, hash = ""] = href.split("#");
	const separator = pathAndQuery.includes("?") ? "&" : "?";
	return `${pathAndQuery}${separator}returnTo=${encodeURIComponent(redirectTo)}${hash ? `#${hash}` : ""}`;
}

const noteHref = buildNoteHref(hrefOverride ?? item.href);
const titleHtml = searchQuery
	? highlightSearchText(item.title, searchQuery, { field: "title" })
	: null;
const snippetHtml = searchQuery && searchSnippet && searchField
	? highlightSearchText(searchSnippet, searchQuery, { field: searchField })
	: null;
---

<article class="group">
	<div class="relative rounded-[14px] px-3 py-3 transition hover:bg-[#fcfaf6]">
		<a href={noteHref} class="flex min-w-0 items-start gap-4">
			{
				item.imageUrl ? (
					<img
						src={item.imageUrl}
						alt=""
						class="h-12 w-12 shrink-0 rounded-[10px] object-cover"
						loading="lazy"
					/>
				) : (
					<div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-[10px] bg-[#f4efe7] text-xs font-semibold text-slate-500">
						{item.domainLabel.slice(0, 2)}
					</div>
				)
			}
			<div class="min-w-0 flex-1">
				<div class="flex min-w-0 items-start justify-between gap-3 pr-12">
					<div class="min-w-0 flex-1">
						{
							titleHtml ? (
								<h2 class="truncate text-[1.05rem] font-semibold tracking-tight text-slate-900" set:html={titleHtml}></h2>
							) : (
								<h2 class="truncate text-[1.05rem] font-semibold tracking-tight text-slate-900">
									{item.title}
								</h2>
							)
						}
					</div>
					<div class="flex shrink-0 items-center gap-4">
						<span class="text-sm text-slate-500">{item.updatedLabel}</span>
					</div>
				</div>
				{
					snippetHtml && (
						<p class="mt-1 text-sm leading-6 text-slate-600" set:html={snippetHtml}></p>
					)
				}
				<LibraryTagPreview
					tags={item.tags}
					selectedTags={selectedTags}
					searchQuery={searchQuery}
					class="mt-2"
				/>
			</div>
		</a>
		<div class="absolute right-3 top-3">
			<FavoriteToggleButton noteId={item.id} isFavorite={Boolean(item.favorite)} redirectTo={redirectTo} />
		</div>
	</div>
</article>
