---
import { Marked } from "marked";
import Icon from "src/components/Icon.astro";
import { getCalloutAppearance } from "./calloutDefinitions";

interface Props {
	calloutType: string;
	title: string;
	collapsible: boolean;
	collapsed: boolean;
}

const { calloutType, title, collapsible, collapsed } = Astro.props;
const inlineMarkdown = new Marked({ gfm: true, breaks: true });

function renderInlineMarkdown(value: string) {
	const parsed = inlineMarkdown.parseInline(value);
	return typeof parsed === "string" ? parsed : value;
}

const appearance = getCalloutAppearance(calloutType);
const titleHtml = renderInlineMarkdown(title);
---

{
	collapsible ? (
		<details
			class:list={["obsidian-callout", appearance.tone]}
			data-callout={appearance.kind}
			open={!collapsed}
		>
			<summary class="obsidian-callout__summary">
				<span class="obsidian-callout__summary-main">
					<Icon name={appearance.icon} class="obsidian-callout__icon" />
					<span class="obsidian-callout__title" set:html={titleHtml}></span>
				</span>
				<Icon name="chevron-right" class="obsidian-callout__chevron" />
			</summary>
			<div class="obsidian-callout__content">
				<slot />
			</div>
		</details>
	) : (
		<section
			class:list={["obsidian-callout", appearance.tone]}
			data-callout={appearance.kind}
		>
			<div class="obsidian-callout__summary obsidian-callout__summary--static">
				<span class="obsidian-callout__summary-main">
					<Icon name={appearance.icon} class="obsidian-callout__icon" />
					<span class="obsidian-callout__title" set:html={titleHtml}></span>
				</span>
			</div>
			<div class="obsidian-callout__content">
				<slot />
			</div>
		</section>
	)
}

<style>
	.obsidian-callout {
		--callout-rgb: 68, 138, 255;
		--callout-accent: rgb(var(--callout-rgb));
		--callout-bg: rgba(var(--callout-rgb), 0.075);
		--callout-border: rgba(var(--callout-rgb), 0.3);
		--callout-text: #334155;
		overflow: hidden;
		border: 1px solid var(--callout-border);
		border-top-width: 3px;
		border-radius: 1.05rem;
		background: linear-gradient(180deg, #ffffff 0%, var(--callout-bg) 100%);
		box-shadow: 0 10px 22px rgba(15, 23, 42, 0.045);
		color: var(--callout-text);
	}

	.obsidian-callout--note {
		--callout-rgb: 68, 138, 255;
	}

	.obsidian-callout--abstract,
	.obsidian-callout--tip {
		--callout-rgb: 0, 191, 188;
	}

	.obsidian-callout--info,
	.obsidian-callout--todo {
		--callout-rgb: 0, 184, 212;
	}

	.obsidian-callout--success {
		--callout-rgb: 0, 200, 83;
	}

	.obsidian-callout--question {
		--callout-rgb: 100, 221, 23;
	}

	.obsidian-callout--warning {
		--callout-rgb: 255, 145, 0;
	}

	.obsidian-callout--failure {
		--callout-rgb: 255, 82, 82;
	}

	.obsidian-callout--danger {
		--callout-rgb: 255, 23, 68;
	}

	.obsidian-callout--bug {
		--callout-rgb: 245, 0, 87;
	}

	.obsidian-callout--example {
		--callout-rgb: 124, 77, 255;
	}

	.obsidian-callout--quote {
		--callout-rgb: 158, 158, 158;
	}

	.obsidian-callout__summary {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.85rem;
		padding: 0.8rem 1rem;
		cursor: pointer;
		list-style: none;
		user-select: none;
		color: inherit;
	}

	.obsidian-callout__summary--static {
		cursor: default;
	}

	.obsidian-callout__summary-main {
		display: inline-flex;
		min-width: 0;
		align-items: center;
		gap: 0.58rem;
	}

	.obsidian-callout :global(.obsidian-callout__icon) {
		flex-shrink: 0;
		width: 1.08rem;
		height: 1.08rem;
		color: var(--callout-accent);
		opacity: 0.95;
	}

	.obsidian-callout__title {
		min-width: 0;
		font-size: 0.98rem;
		font-weight: 700;
		line-height: 1.35;
		letter-spacing: -0.01em;
		color: inherit;
	}

	.obsidian-callout__title :global(strong) {
		font-weight: 800;
	}

	.obsidian-callout__title :global(code) {
		padding: 0.1rem 0.35rem;
		border-radius: 0.45rem;
		background: rgba(255, 255, 255, 0.72);
		font-size: 0.92em;
	}

	.obsidian-callout :global(.obsidian-callout__chevron) {
		flex-shrink: 0;
		width: 0.9rem;
		height: 0.9rem;
		color: var(--callout-accent);
		transition: transform 140ms ease;
	}

	.obsidian-callout[open] :global(.obsidian-callout__chevron) {
		transform: rotate(90deg);
	}

	.obsidian-callout__content {
		padding: 0 1rem 0.95rem;
	}

	.obsidian-callout__content :global(.note-content) {
		color: inherit;
	}

	.obsidian-callout__content :global(.note-content > :first-child) {
		margin-top: 0;
	}

	.obsidian-callout__content :global(.note-content > :last-child) {
		margin-bottom: 0;
	}

	.obsidian-callout summary::-webkit-details-marker {
		display: none;
	}

	.obsidian-callout summary::marker {
		display: none;
	}

	@media (max-width: 768px) {
		.obsidian-callout__summary {
			min-height: 2.75rem;
			padding: 0.7rem 0.8rem;
		}

		.obsidian-callout__content {
			padding: 0 0.8rem 0.8rem;
		}
	}
</style>
