---
import type { LibraryItem } from "../lib/vault";
import FavoriteToggleButton from "./FavoriteToggleButton.astro";
import TagChip from "./TagChip.astro";

interface Props {
	item: LibraryItem;
}

const { item } = Astro.props;
const redirectTo = Astro.url.pathname + Astro.url.search;
---

<article class="relative overflow-hidden rounded-[14px] border border-[#ece5dc] bg-white shadow-[0_8px_20px_rgba(15,23,42,0.04)]">
	<div class="absolute right-3 top-3 z-10">
		<FavoriteToggleButton
			noteId={item.id}
			isFavorite={Boolean(item.favorite)}
			redirectTo={redirectTo}
		/>
	</div>
	<a href={item.href} class="block">
		{
			item.imageUrl ? (
				<img
					src={item.imageUrl}
					alt=""
					class="h-44 w-full object-cover"
					loading="lazy"
				/>
			) : (
				<div class="flex h-44 w-full items-end bg-[linear-gradient(135deg,#dbe4f0_0%,#f3ede4_100%)] p-4">
					<span class="rounded-full bg-white/80 px-3 py-1 text-xs font-semibold text-slate-600">
						{item.categoryLabel}
					</span>
				</div>
			)
		}
		<div class="space-y-3 p-4">
			<TagChip label={item.categoryLabel} tone={item.tone} />
			<div>
				<h3 class="text-[1.05rem] font-semibold tracking-tight text-slate-900">
					{item.title}
				</h3>
				<p class="mt-1 text-sm text-slate-500">{item.updatedLabel}</p>
			</div>
		</div>
	</a>
</article>
