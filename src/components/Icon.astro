---
interface Props {
	name: string;
	class?: string;
}

const { name, class: className = "h-4 w-4" } = Astro.props;
---

<svg
	class={className}
	viewBox="0 0 24 24"
	fill="none"
	stroke="currentColor"
	stroke-width="1.8"
	stroke-linecap="round"
	stroke-linejoin="round"
	aria-hidden="true"
>
	{name === "book-open" && (
		<>
			<path d="M2 7.5A2.5 2.5 0 0 1 4.5 5H10v14H4.5A2.5 2.5 0 0 0 2 21.5z"></path>
			<path d="M22 7.5A2.5 2.5 0 0 0 19.5 5H14v14h5.5a2.5 2.5 0 0 1 2.5 2.5z"></path>
		</>
	)}
	{name === "home" && (
		<>
			<path d="M3 10.5 12 3l9 7.5"></path>
			<path d="M5.5 9.5V20h13V9.5"></path>
		</>
	)}
	{name === "file-text" && (
		<>
			<path d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7z"></path>
			<path d="M14 2v5h5"></path>
			<path d="M9 13h6"></path>
			<path d="M9 17h6"></path>
		</>
	)}
	{name === "star" && (
		<path d="m12 3 2.75 5.57 6.15.9-4.45 4.33 1.05 6.12L12 17.2l-5.5 2.9 1.05-6.12L3.1 9.47l6.15-.9z"></path>
	)}
	{name === "clock-3" && (
		<>
			<circle cx="12" cy="12" r="9"></circle>
			<path d="M12 7.5V12h4"></path>
		</>
	)}
	{name === "book" && (
		<>
			<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
			<path d="M6.5 3H20v18H6.5A2.5 2.5 0 0 1 4 18.5V5.5A2.5 2.5 0 0 1 6.5 3z"></path>
		</>
	)}
	{name === "utensils" && (
		<>
			<path d="M4 3v7a2 2 0 0 0 2 2v9"></path>
			<path d="M8 3v7"></path>
			<path d="M12 3v7"></path>
			<path d="M16 3c0 5 4 5 4 10v8"></path>
		</>
	)}
	{name === "folder" && (
		<>
			<path d="M3 6.5A2.5 2.5 0 0 1 5.5 4H10l2 2h6.5A2.5 2.5 0 0 1 21 8.5v9A2.5 2.5 0 0 1 18.5 20h-13A2.5 2.5 0 0 1 3 17.5z"></path>
		</>
	)}
	{name === "map" && (
		<>
			<path d="m3 6 6-2 6 2 6-2v14l-6 2-6-2-6 2z"></path>
			<path d="M9 4v14"></path>
			<path d="M15 6v14"></path>
		</>
	)}
	{name === "cpu" && (
		<>
			<rect x="7" y="7" width="10" height="10" rx="2"></rect>
			<path d="M4 10h3"></path>
			<path d="M4 14h3"></path>
			<path d="M17 10h3"></path>
			<path d="M17 14h3"></path>
			<path d="M10 4v3"></path>
			<path d="M14 4v3"></path>
			<path d="M10 17v3"></path>
			<path d="M14 17v3"></path>
		</>
	)}
	{name === "dumbbell" && (
		<>
			<path d="M4 10v4"></path>
			<path d="M7 8v8"></path>
			<path d="M17 8v8"></path>
			<path d="M20 10v4"></path>
			<path d="M7 12h10"></path>
		</>
	)}
	{name === "notebook-pen" && (
		<>
			<path d="M5 3h11a2 2 0 0 1 2 2v8"></path>
			<path d="M5 3a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h7"></path>
			<path d="M8 7h6"></path>
			<path d="M8 11h6"></path>
			<path d="m15.5 19.5 4.5-4.5"></path>
			<path d="m18 16 2 2"></path>
		</>
	)}
	{name === "circle" && <circle cx="12" cy="12" r="8"></circle>}
	{name === "tag" && (
		<>
			<path d="M20.6 13.4 12 22l-9-9V4h9z"></path>
			<circle cx="7.5" cy="7.5" r="1"></circle>
		</>
	)}
	{name === "image" && (
		<>
			<rect x="3" y="5" width="18" height="14" rx="2"></rect>
			<circle cx="8.5" cy="10" r="1.5"></circle>
			<path d="m21 15-4.5-4.5L7 20"></path>
		</>
	)}
	{name === "ellipsis" && (
		<>
			<circle cx="6" cy="12" r="1"></circle>
			<circle cx="12" cy="12" r="1"></circle>
			<circle cx="18" cy="12" r="1"></circle>
		</>
	)}
	{name === "pen-line" && (
		<>
			<path d="M12 20h9"></path>
			<path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4z"></path>
		</>
	)}
	{name === "link" && (
		<>
			<path d="M10 13a5 5 0 0 0 7.07 0l1.41-1.41a5 5 0 0 0-7.07-7.07L10 5"></path>
			<path d="M14 11a5 5 0 0 0-7.07 0L5.5 12.41a5 5 0 0 0 7.07 7.07L14 19"></path>
		</>
	)}
	{name === "code" && (
		<>
			<path d="m8 9-4 3 4 3"></path>
			<path d="m16 9 4 3-4 3"></path>
		</>
	)}
	{name === "sparkles" && (
		<>
			<path d="m12 3 1.2 3.3L16.5 7.5l-3.3 1.2L12 12l-1.2-3.3L7.5 7.5l3.3-1.2z"></path>
			<path d="m19 14 .8 2.2L22 17l-2.2.8L19 20l-.8-2.2L16 17l2.2-.8z"></path>
		</>
	)}
	{name === "moon" && (
		<path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 1 0 9.8 9.8z"></path>
	)}
	{name === "trash-2" && (
		<>
			<path d="M3 6h18"></path>
			<path d="M8 6V4h8v2"></path>
			<path d="M19 6l-1 14H6L5 6"></path>
			<path d="M10 11v6"></path>
			<path d="M14 11v6"></path>
		</>
	)}
	{name === "chevron-left" && <path d="m15 18-6-6 6-6"></path>}
	{name === "chevron-down" && <path d="m6 9 6 6 6-6"></path>}
	{name === "layout-list" && (
		<>
			<path d="M8 6h13"></path>
			<path d="M8 12h13"></path>
			<path d="M8 18h13"></path>
			<path d="M3 6h.01"></path>
			<path d="M3 12h.01"></path>
			<path d="M3 18h.01"></path>
		</>
	)}
	{name === "layout-grid" && (
		<>
			<rect x="3" y="3" width="7" height="7" rx="1.5"></rect>
			<rect x="14" y="3" width="7" height="7" rx="1.5"></rect>
			<rect x="3" y="14" width="7" height="7" rx="1.5"></rect>
			<rect x="14" y="14" width="7" height="7" rx="1.5"></rect>
		</>
	)}
	{name === "search" && (
		<>
			<circle cx="11" cy="11" r="7"></circle>
			<path d="m20 20-3.5-3.5"></path>
		</>
	)}
</svg>
