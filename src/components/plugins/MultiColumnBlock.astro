---
import type { LibraryItem } from "../../lib/vault";
import NoteContent from "../notes/NoteContent.astro";

interface Props {
	note: LibraryItem;
	columns: string[];
	columnCount: number;
}

const { note, columns, columnCount } = Astro.props;
const gridColumns = Math.max(1, Math.min(columnCount || columns.length || 1, 4));
---

<section class="surface-card overflow-hidden border-[#e5ddd1] bg-white p-4 shadow-[0_12px_28px_rgba(15,23,42,0.05)] md:p-5">
	<div class="multi-column-grid" style={`--muninn-column-count:${gridColumns}`}>
		{
			columns.map((column) => (
				<div class="multi-column-grid__column rounded-[20px] border border-[#ece4d8] bg-[linear-gradient(180deg,#fffdfa_0%,#fbf8f2_100%)] p-4">
					<NoteContent note={note} content={column} />
				</div>
			))
		}
	</div>
</section>

<style>
	.multi-column-grid {
		display: grid;
		gap: 1rem;
		grid-template-columns: repeat(var(--muninn-column-count), minmax(0, 1fr));
	}

	@media (max-width: 960px) {
		.multi-column-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
