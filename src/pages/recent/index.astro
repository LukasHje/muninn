---
import { ui, withSiteName } from "i18n";
import VaultNotesBrowser from "components/VaultNotesBrowser.astro";
import MainLayout from "layouts/MainLayout.astro";
import { getRecentVaultItemsWithinDay } from "lib/vault";

const recentItems = await getRecentVaultItemsWithinDay();
---

<MainLayout title={withSiteName(ui.pages.recent.title)}>
	<VaultNotesBrowser
		title={ui.pages.recent.title}
		items={recentItems}
		emptyMessage={ui.pages.recent.empty}
		basePath="/recent"
	/>
</MainLayout>
