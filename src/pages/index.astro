---
import DashboardCard from "src/components/DashboardCard.astro";
import FavoritesList from "src/components/FavoritesList.astro";
import Hero from "src/components/Hero.astro";
import NoteCard from "src/components/NoteCard.astro";
import ScratchpadComposer from "src/components/ScratchpadComposer.astro";
import SectionCard from "src/components/SectionCard.astro";
import TagChip from "src/components/TagChip.astro";
import TodayNoteCard from "src/components/TodayNoteCard.astro";
import { ui, withSiteName } from "src/i18n";
import MainLayout from "src/layouts/MainLayout.astro";
import {
	getDashboardHero,
	getDashboardMetrics,
	getFavoriteLinks,
	getPopularTags,
	getRecentItems,
	getTodayEntry,
} from "src/lib/vault";

const [dashboardHero, dashboardMetrics, favoriteLinks, popularTags, recentItems, todayEntry] =
	await Promise.all([
		getDashboardHero(),
		getDashboardMetrics(),
		getFavoriteLinks(),
		getPopularTags(),
		getRecentItems(),
		getTodayEntry(),
	]);
---

<MainLayout title={withSiteName(ui.pages.dashboardTitle)}>
	<div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_340px]">
		<div class="space-y-6">
			<Hero
				title={dashboardHero.title}
				description={dashboardHero.description}
				imageUrl={dashboardHero.imageUrl}
			/>

			<section class="grid gap-4 md:grid-cols-2 2xl:grid-cols-4">
				{
					dashboardMetrics.map((metric) => (
						<DashboardCard metric={metric} />
					))
				}
			</section>

			<SectionCard title={ui.dashboard.recentlyUpdated}>
				<a
					slot="actions"
					href="/notes"
					class="text-sm font-medium text-slate-500 transition hover:text-slate-900"
				>
					{ui.dashboard.viewAll} →
				</a>
				<div class="grid gap-4 md:grid-cols-2 2xl:grid-cols-4">
					{
						recentItems.map((item) => (
							<NoteCard item={item} />
						))
					}
				</div>
			</SectionCard>

			<SectionCard title={ui.dashboard.popularTags}>
				<div class="flex flex-wrap gap-3">
					{
						popularTags.map((tag) => (
							<TagChip label={tag.label} count={tag.count} tone={tag.tone} />
						))
					}
				</div>
			</SectionCard>
		</div>

		<div class="space-y-6">
			{todayEntry && <TodayNoteCard entry={todayEntry} />}
			<ScratchpadComposer />
			<FavoritesList items={favoriteLinks} />
		</div>
	</div>
</MainLayout>
