---
import Hero from "src/components/Hero.astro";
import NoteCard from "src/components/NoteCard.astro";
import RecipeLayout from "src/layouts/RecipeLayout.astro";
import SectionCard from "src/components/SectionCard.astro";
import { ui, withSiteName } from "src/i18n";
import { getDashboardHero, getItemsByCategory } from "src/lib/vault";

const [recipes, dashboardHero] = await Promise.all([
	getItemsByCategory("recept"),
	getDashboardHero(),
]);
---

<RecipeLayout title={withSiteName(ui.pages.recipes.title)}>
	<Hero
		eyebrow={ui.pages.recipes.eyebrow}
		title={ui.pages.recipes.heroTitle}
		description={ui.pages.recipes.heroDescription}
		imageUrl={dashboardHero.imageUrl}
	/>

	<SectionCard title={ui.pages.recipes.sectionTitle}>
		<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
			{
				recipes.map((recipe) => (
					<NoteCard item={recipe} />
				))
			}
		</div>
	</SectionCard>
</RecipeLayout>
