---
import Hero from "components/Hero.astro";
import NoteCard from "components/NoteCard.astro";
import BookLayout from "layouts/BookLayout.astro";
import SectionCard from "components/SectionCard.astro";
import { ui, withSiteName } from "i18n";
import { getDashboardHero, getItemsByCategory } from "lib/vault";

const [books, dashboardHero] = await Promise.all([
	getItemsByCategory("bocker"),
	getDashboardHero(),
]);
---

<BookLayout title={withSiteName(ui.pages.books.title)}>
	<Hero
		eyebrow={ui.pages.books.eyebrow}
		title={ui.pages.books.heroTitle}
		description={ui.pages.books.heroDescription}
		imageUrl={dashboardHero.imageUrl}
	/>

	<SectionCard title={ui.pages.books.sectionTitle}>
		<div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
			{
				books.map((book) => (
					<NoteCard item={book} />
				))
			}
		</div>
	</SectionCard>
</BookLayout>
