---
import { ui, withSiteName } from "src/i18n";
import VaultNotesBrowser from "src/components/VaultNotesBrowser.astro";
import MainLayout from "src/layouts/MainLayout.astro";
import { getFavoriteLibraryItems } from "src/lib/vault";

const favoriteItems = await getFavoriteLibraryItems();
---

<MainLayout title={withSiteName(ui.pages.favorites.title)}>
	<VaultNotesBrowser
		title={ui.pages.favorites.title}
		items={favoriteItems}
		emptyMessage={ui.pages.favorites.empty}
		basePath="/favorites"
	/>
</MainLayout>
