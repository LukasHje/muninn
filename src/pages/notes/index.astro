---
import { ui, withSiteName } from "i18n";
import VaultNotesBrowser from "components/VaultNotesBrowser.astro";
import MainLayout from "layouts/MainLayout.astro";
import { getLibraryItems } from "lib/vault";

const libraryItems = await getLibraryItems();
---

<MainLayout title={withSiteName(ui.pages.allNotes.title)}>
	<VaultNotesBrowser
		title={ui.pages.allNotes.title}
		items={libraryItems}
		emptyMessage={ui.pages.allNotes.empty}
		basePath="/notes"
	/>
</MainLayout>
